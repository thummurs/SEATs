# PostgreSQL (local for now, will swap to Supabase in Phase 3)
DB_NAME=seats_db
DB_USER=ruthwikt
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# API Security
# Generate a strong random key — run this in terminal to make one:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEY=replace_this_with_your_generated_key

# Flask
FLASK_ENV=development
FLASK_PORT=3000
